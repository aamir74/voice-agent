# ---- LiveKit ----
# For local dev with `livekit-server --dev`, the defaults below work as-is.
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# ---- Groq (Speech-to-Text, OpenAI-compatible) ----
GROQ_API_KEY=your-groq-api-key
GROQ_BASE_URL=https://api.groq.com/openai/v1
STT_MODEL=whisper-large-v3

# ---- Google Gemini (LLM via OpenAI-compat + embeddings via native SDK) ----
GEMINI_API_KEY=your-gemini-api-key
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=gemini-embedding-001

# ---- Kokoro TTS (local ONNX) ----
# Download the model files into backend/models/ (see README).
KOKORO_MODEL_PATH=models/kokoro-v1.0.onnx
KOKORO_VOICES_PATH=models/voices-v1.0.bin
KOKORO_VOICE=af_heart

# ---- Storage ----
DATA_DIR=data
CHROMA_DIR=data/chroma
COLLECTION_NAME=knowledge_base

# ---- RAG ----
CHUNK_SIZE=800
CHUNK_OVERLAP=100
RETRIEVAL_TOP_K=4

# ---- Server ----
CORS_ORIGINS=http://localhost:5173
